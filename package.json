{
  "name": "ap",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @ap/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @ap/api exec prisma db seed",
    "db:studio": "pnpm --filter @ap/api exec prisma studio",
    "db:generate": "pnpm --filter @ap/api exec prisma generate",
    "db:reset": "pnpm --filter @ap/api exec prisma migrate reset"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "zod": "3.24.2"
    }
  }
}

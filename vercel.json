{
  "version": 2,
  "buildCommand": "pnpm --filter @ap/api build",
  "outputDirectory": "public",
  "installCommand": "pnpm install && pnpm --filter @ap/api exec prisma generate",
  "builds": [
    {
      "src": "apps/api/src/lambda.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/api/src/lambda.ts"
    }
  ]
}
